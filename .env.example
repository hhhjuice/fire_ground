# Ground fire enhancement system - environment variables
# Prefix: GROUND_

# NASA FIRMS API Key (free, request at https://firms.modaps.eosdis.nasa.gov/api/map_key/)
GROUND_FIRMS_MAP_KEY=your_firms_map_key_here

# FIRMS likelihood ratios per FirmsMatchLevel
GROUND_FIRMS_LR_EXACT_MATCH=4.0
GROUND_FIRMS_LR_NEARBY_SAME_SEASON=2.5
GROUND_FIRMS_LR_REGIONAL=1.5
GROUND_FIRMS_LR_NO_SEASON_RECORD=0.8
GROUND_FIRMS_LR_NO_HISTORY=0.5
GROUND_FIRMS_LR_CONFIRMED_NONE=0.3

# Industrial facility delta per IndustrialProximity (logit space)
GROUND_INDUSTRIAL_DELTA_WITHIN_500M=-2.5
GROUND_INDUSTRIAL_DELTA_WITHIN_2KM=-1.5
GROUND_INDUSTRIAL_DELTA_WITHIN_5KM=-0.8
GROUND_INDUSTRIAL_DELTA_NONE=0.3

# Cache settings
GROUND_CACHE_TTL_SECONDS=3600
GROUND_CACHE_MAX_SIZE=1000

# Database path
GROUND_DB_PATH=data/fire_ground.db

# HTTP timeout in seconds
GROUND_HTTP_TIMEOUT=10.0
